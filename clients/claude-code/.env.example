# Claude Code notification hook config (see install.md).
# These must be set in the shell Claude Code runs in (e.g. ~/.zshrc), not
# necessarily as a literal .env file -- the hook reads process.env directly.

# --- Gateway connection (required) ---
NOTIFY_URL=http://localhost:8080/notify
NOTIFY_TOKEN=

# --- Per-event toggles (optional; default enabled, set to "false" to silence) ---
NOTIFY_ON_START=true
NOTIFY_ON_END=true
NOTIFY_ON_NEEDS_INPUT=true
