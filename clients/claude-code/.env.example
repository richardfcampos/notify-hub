# Claude Code notification hook config (see install.md).
#
# Two ways to supply these: as real shell env vars (e.g. exported from
# ~/.zshrc), or as a KEY=VALUE file at ~/.config/notify-hub/hook.env (no
# shell profile edits needed -- recommended for a zero-setup, all-projects
# install). Env vars always win when both are present; this file's values
# fill in whatever env doesn't set. Point the hook at a different config
# file with NOTIFY_HOOK_CONFIG=/path/to/hook.env.

# --- Gateway connection (required) ---
NOTIFY_URL=http://localhost:8080/notify
NOTIFY_TOKEN=

# --- Per-event toggles (optional) ---
# NOTIFY_ON_START defaults to OFF (must be explicitly "true" to enable) --
# the task's start time is always cached silently for duration, regardless
# of this toggle. NOTIFY_ON_END/NOTIFY_ON_NEEDS_INPUT default to ON; set
# either to "false" to silence it.
NOTIFY_ON_START=false
NOTIFY_ON_END=true
NOTIFY_ON_NEEDS_INPUT=true

# --- Idle debounce for the "end" push (optional) ---
# Claude Code's Stop event fires at the end of EVERY assistant turn, not
# just when a task is truly done -- without debouncing you get flooded
# with a push per conversational reply. NOTIFY_IDLE_SECONDS defaults to
# 180: an "end" push is held for that many quiet seconds (no new prompt in
# the same session) before it actually sends, so a burst of back-and-forth
# turns collapses into a single push once you stop responding. If you
# submit another prompt before the window elapses, the held push is
# cancelled outright (you were still there, no notification needed). Set
# to "0" to restore the old immediate-send-on-every-Stop behavior.
NOTIFY_IDLE_SECONDS=180
