# Local TTS player config (spec LTTS-01, .specs/features/local-tts-channel/).
#
# This service runs OUTSIDE Docker, directly on the host Mac (Docker
# Desktop for Mac has no CoreAudio access from inside a container). It
# binds 127.0.0.1 only -- reachable from this machine and, from inside the
# notify-hub worker container, via http://host.docker.internal:<PORT>.

# Port the player's HTTP API listens on (loopback-only).
PORT=8082

# Voice used by POST /speak when the request omits `voice` or the
# requested voice is unknown -- must be one of the EXACT names returned by
# GET /voices (see say -v '?' for the full list installed on this Mac).
DEFAULT_VOICE=Luciana
