{
  "name": "notify-hub",
  "version": "0.1.0",
  "description": "Self-hosted, free, multi-channel notification gateway (ntfy, Telegram, Email, Slack, Discord, WhatsApp) with token auth and a durable queue. Ships a Claude Code hook and an MCP server.",
  "license": "MIT",
  "author": "Richard Campos",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/richardfcampos/notify-hub.git"
  },
  "homepage": "https://github.com/richardfcampos/notify-hub#readme",
  "bugs": {
    "url": "https://github.com/richardfcampos/notify-hub/issues"
  },
  "keywords": [
    "notifications",
    "push-notifications",
    "self-hosted",
    "notification-gateway",
    "ntfy",
    "telegram",
    "discord",
    "slack",
    "whatsapp",
    "webhook",
    "bullmq",
    "fastify",
    "claude-code",
    "mcp",
    "mcp-server"
  ],
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run build:copy-admin-ui",
    "build:copy-admin-ui": "mkdir -p dist/admin/ui && cp -R src/admin/ui/. dist/admin/ui/",
    "test": "vitest run",
    "test:unit": "vitest run src",
    "test:integration": "vitest run test/integration/bullmq-retry.integration.test.ts",
    "start:api": "node dist/bin/api.js",
    "start:worker": "node dist/bin/worker.js",
    "start:mcp": "node dist/bin/mcp.js",
    "dev:api": "tsx src/bin/api.ts",
    "dev:worker": "tsx src/bin/worker.ts",
    "admin": "tsx src/bin/admin.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.11.1",
    "bullmq": "^5.80.2",
    "fastify": "^5.10.0",
    "ioredis": "^5.11.1",
    "nodemailer": "^9.0.3",
    "pino": "^9.14.0",
    "posthog-node": "^5.45.2",
    "zod": "^3.25.76"
  },
  "overrides": {
    "ioredis": "$ioredis"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.20.1",
    "@types/nodemailer": "^6.4.24",
    "pino-pretty": "^13.1.3",
    "testcontainers": "^12.0.4",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
