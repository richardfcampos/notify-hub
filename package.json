{
  "name": "notify-hub",
  "version": "0.1.0",
  "description": "Self-hosted, free, multi-channel notification gateway (ntfy, Telegram, Email, Slack, Discord, WhatsApp) with token auth and a durable queue.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:unit": "vitest run src",
    "test:integration": "vitest run test/integration/bullmq-retry.integration.test.ts",
    "start:api": "node dist/bin/api.js",
    "start:worker": "node dist/bin/worker.js",
    "dev:api": "tsx src/bin/api.ts",
    "dev:worker": "tsx src/bin/worker.ts"
  },
  "dependencies": {
    "bullmq": "^5.80.2",
    "fastify": "^5.10.0",
    "ioredis": "^5.11.1",
    "nodemailer": "^9.0.3",
    "pino": "^9.14.0",
    "zod": "^3.25.76"
  },
  "overrides": {
    "ioredis": "$ioredis"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@types/nodemailer": "^6.4.24",
    "pino-pretty": "^13.1.3",
    "testcontainers": "^12.0.4",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
