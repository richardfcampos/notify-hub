# =============================================================================
# Channels and profiles now live in SQLite, managed live from the admin panel
# (http://127.0.0.1:8081) -- add/edit/delete named channel instances (e.g.
# multiple Slack instances, one per company) and token profiles there, no
# restart needed (hot-reload). The TOKENS / CHANNELS_ENABLED / per-channel
# vars below are read ONLY ONCE, as a one-time seed, when the service starts
# with an EMPTY database (spec DBCH-03). Once the DB has any channel in it,
# these vars are ignored -- edit config in the panel from then on.
# =============================================================================

# --- Server ---
PORT=8080

# --- Queue (Redis / BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Config store (SQLite) ---
# Path to the SQLite file backing channels/profiles (DBCH-01). Compose sets
# this to /data/notify-hub.db on the shared `notify-data` volume so
# api/worker/admin all read/write the same file; only override this for
# host-mode (`npm run dev:api` / `npm run admin`) if you want a non-default
# location.
DB_PATH=./data/notify-hub.db

# --- Auth: token -> profile mapping (FIRST-BOOT SEED ONLY, see header above) ---
# Format (documented in src/config/load-config.ts): one profile per `;`-separated
# entry, fields separated by `:` -- name:token:defaultChannel1,defaultChannel2
# Example: "phone:supersecrettoken:ntfy,telegram;desktop:othertoken:discord"
TOKENS=

# --- Channels enabled globally (comma-separated) (FIRST-BOOT SEED ONLY) ---
# e.g. CHANNELS_ENABLED=ntfy,telegram,email,slack,discord,whatsapp,webhook
CHANNELS_ENABLED=

# --- ntfy ---
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Email (SMTP via nodemailer) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_TO=

# --- Slack ---
SLACK_WEBHOOK_URL=

# --- Discord ---
DISCORD_WEBHOOK_URL=

# --- WhatsApp (CallMeBot) ---
WHATSAPP_PHONE=
WHATSAPP_APIKEY=

# --- Generic webhook ---
WEBHOOK_URL=

# --- Retry / backoff (delivery queue) ---
RETRY_ATTEMPTS=5
RETRY_BACKOFF_MS=2000

# --- Telemetry (opt-in, OFF by default) ---
# notify-hub can send ONE small anonymous "heartbeat" event per process boot
# (api and worker each send their own) to help the maintainer gauge adoption.
# Default is OFF -- opting in is a deliberate choice made once in
# scripts/setup-env.sh, or by hand by setting this to true. Fields ever sent:
# version, channelTypesEnabled (channel TYPES only, e.g. ntfy,slack -- NEVER
# instance names/labels/credentials/message content), platform, plus a
# randomly-generated anonymous install id (no hostname/IP/MAC/personal info).
# Full disclosure, exact source files to audit, and both opt-out mechanisms:
# see ./TELEMETRY.md.
TELEMETRY_ENABLED=false

# Hard kill switch, respected regardless of TELEMETRY_ENABLED above -- the
# informal cross-tool convention (Homebrew, Next.js, ...) also respected by
# many other tools. Set to any value to disable telemetry unconditionally,
# even if TELEMETRY_ENABLED=true.
#DO_NOT_TRACK=1

# PostHog Project API Key used to send the heartbeat above (write-only key,
# safe to be public -- see TELEMETRY.md). Left unset here on purpose: if
# empty, telemetry -- even when opted in above -- has nowhere to send events
# and silently no-ops (never blocks boot, never errors). The project's own
# default aggregate endpoint, once the maintainer configures one, may be
# documented separately; for now, set your OWN PostHog key here to activate
# real sending.
POSTHOG_API_KEY=

# --- Admin panel ---
# Dashboard binds 127.0.0.1 only (host mode: `npm run admin`; also ships as
# the `admin` service in `docker compose up -d`, mapped 127.0.0.1:8081 on
# the host side). Not read from this file by the panel itself -- set it in
# your shell env if you need a port other than 8081; compose picks it up
# too since ADMIN_PORT is exported to the `admin` service's environment.
ADMIN_PORT=8081

# Host-side bind for the admin panel port mapping (docker compose).
# Default 0.0.0.0 = reachable from your other devices (LAN/Tailscale).
# Set to 127.0.0.1 to make the panel localhost-only.
#ADMIN_BIND=0.0.0.0
